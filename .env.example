# LLM Wiki — Environment Variables
# Copy to .env and fill in your API keys.

# Groq (free tier: 14,400 req/day)
# WIKI_GROQ_API_KEY=gsk_...

# Google Gemini (free tier: 1,500 req/day)
# WIKI_GEMINI_API_KEY=AI...

# Ollama (local, no key needed)
# WIKI_OLLAMA_HOST=http://127.0.0.1:11434
# WIKI_OLLAMA_MODEL=ollama/qwen3:4b

# Wiki settings
# WIKI_WIKI_DIR=wiki
# WIKI_SOURCES_DIR=sources
# WIKI_LOG_LEVEL=INFO
